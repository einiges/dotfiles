#!/bin/bash

# 1 exit code
help() {
	printf 'Usage: %s DESTINATION SOURCE...\n' "$(basename "$0")"
	exit ${1:-1}
}


arg_destination=
arg_sources=()

main() {
	parse_args "$@"
	archive_all "$arg_destination" "${arg_sources[@]}"
}

# 1... sources
source_is_tar() {
	[ $# -ne 1 ] &&
		return 1

	case "$1" in
		*.tar) ;;
		*) return 1 ;;
	esac

	return 0
}

# 1... args
parse_args() {
	if [ $# -lt 2 ]; then
		help
	fi

	arg_destination="$1"
	arg_sources=( "${@:2}" )
}


# 1 destination
# 2... sources
archive_all() {
	archive="$1"
	sources=( "${@:2}" )

	# TODO: Omit specifying commands twice, to prevent nesting tar.

	case "$archive" in
		*.tar)
			tar --create --file="$archive" -- "${sources[@]}"
			;;
		*.tar.gz|*.tgz)
			if source_is_tar "${sources[@]}"
			then gzip --stdout --force --quiet -- "$source" > "$archive"
			else tar --gzip --create --file="$archive" -- "${sources[@]}"
			fi
			;;
		*.gz)
			if [ ${#sources[@]} -gt 1 ]
			then die "unable to compress multiple files in one gzip-archive"
			else gzip --stdout --force --quiet -- "$source" > "$archive"
			fi
			;;
		*.tar.bz2|*.tbz2|*.tbz)
			if source_is_tar "${sources[@]}"
			then bzip2 --stdout --force --quiet -- "$source" > "$archive"
			else tar --bzip2 --create --file="$archive" -- "${sources[@]}"
			fi
			;;
		*.bz2)
			if [ ${#sources[@]} -gt 1 ]
			then die "unable to compress multiple files as one bzip2-archive"
			else bzip2 --stdout --force --quiet -- "$source" > "$archive"
			fi
			;;
		*.tar.xz|*.txz)
			if source_is_tar "${sources[@]}"
			then xz --stdout --force --quiet -- "${sources[@]}" > "$archive"
			else tar --xz --create --file="$archive" -- "${sources[@]}"
			fi
			;;
		*.xz)
			if [ ${#sources[@]} -gt 1 ]
			then die "unable to compress multiple files in one xz-archive"
			else xz --stdout --force --quiet -- "${sources[@]}" > "$archive"
			fi
			;;
		*.tar.lzma|*.tlz)
			if source_is_tar "${sources[@]}"
			then lzma --stdout --force --quiet -- "${sources[@]}" > "$archive"
			else tar --lzma --create --file="$archive" -- "${sources[@]}"
			fi
			;;
		*.lzma|*.lz)
			if [ ${#sources[@]} -gt 1 ]
			then die "unable to compress multiple files in one lzma-archive"
			else lzma --stdout --force --quiet -- "${sources[@]}" > "$archive"
			fi
			;;
		*.tar.zst|*.tzst)
			if source_is_tar "${sources[@]}"
			then zstd --stdout --force --quiet -- "${sources[@]}" > "$archive"
			else tar --zstd --create --file="$archive" -- "${sources[@]}"
			fi
			;;
		*.zst)
			if [ ${#sources[@]} -gt 1 ]
			then die "unable to compress multiple files as one zstd-archive"
			else zstd --stdout --force --quiet -- "${sources[@]}" > "$archive"
			fi
			;;
		*.zip)
			zip --quiet --recurse-paths "$archive" -- "${sources[@]}"
			;;
		*.7z)
			7z a -t7z -- "$archive" "${sources[@]}" >/dev/null
			;;

		* ) die "unsupported archive for '$archive'" ;;
	esac
}

die() {
	printf '%s\n' "$*" >&2
	exit 1
}


main "$@"

